<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4f46e5;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background Circle -->
  <circle cx="24" cy="24" r="22" fill="url(#logoGradient)" stroke="white" stroke-width="2"/>
  
  <!-- Vault Door -->
  <circle cx="24" cy="24" r="16" fill="none" stroke="white" stroke-width="2"/>
  <circle cx="24" cy="24" r="12" fill="none" stroke="white" stroke-width="1.5"/>
  <circle cx="24" cy="24" r="8" fill="none" stroke="white" stroke-width="1"/>
  
  <!-- Digital Elements -->
  <rect x="20" y="16" width="1" height="4" fill="white" opacity="0.8"/>
  <rect x="22" y="14" width="1" height="6" fill="white" opacity="0.8"/>
  <rect x="24" y="12" width="1" height="8" fill="white" opacity="0.8"/>
  <rect x="26" y="14" width="1" height="6" fill="white" opacity="0.8"/>
  <rect x="28" y="16" width="1" height="4" fill="white" opacity="0.8"/>
  
  <!-- Central Lock -->
  <circle cx="24" cy="24" r="3" fill="white"/>
  <circle cx="24" cy="24" r="1.5" fill="url(#logoGradient)"/>
  
  <!-- Corner Accents -->
  <path d="M8 16 L12 12 L16 16" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>
  <path d="M32 16 L36 12 L40 16" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>
  <path d="M8 32 L12 36 L16 32" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>
  <path d="M32 32 L36 36 L40 32" stroke="white" stroke-width="2" fill="none" opacity="0.6"/>
</svg>
